# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional overrides
DEFAULT_MODEL=claude-3-5-haiku-latest
DEFAULT_MAX_TOKENS=1024
REQUEST_TIMEOUT_S=60

# Microbatching (opt-in, off by default). When enabled, concurrent requests
# are grouped into a short admission window and dispatched as concurrency-
# limited realtime upstream calls.
BATCH_ENABLED=0
BATCH_MAX_SIZE=16
BATCH_MAX_WAIT_MS=20
BATCH_MAX_CONCURRENCY=8
BATCH_TIMEOUT_S=60

# Cost and latency observatory (opt-in, off by default). When enabled, the
# proxy records one sample per request and serves a JSON snapshot at
# GET /metrics. While disabled, that endpoint returns 404.
METRICS_ENABLED=0
METRICS_LATENCY_WINDOW=1024
